# RelayRS Configuration

# Storage Engine Configuration
STORAGE_ENGINE=sqlite
STORAGE_PATH=./relay_queue.db
STORAGE_MAX_ENTRIES=50000
STORAGE_MAX_SIZE_MB=500
STORAGE_TTL_HOURS=24
STORAGE_SUCCESS_PURGE=true
STORAGE_BATCH_PRUNE_INTERVAL_SEC=600

# Network Configuration
NETWORK_REMOTE_URL=http://localhost:3000/webhook
NETWORK_CALLBACK_URL=http://localhost:8080/callback
NETWORK_RETRY_BACKOFF_SEC=2

# Worker Configuration
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_CONFIG_SYNC_INTERVAL_SECONDS=60
WORKER_MAX_RETRIES=5
WORKER_BATCH_SIZE=10

# Log level
RUST_LOG=info
